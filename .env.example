# === Atlantic to Kindle — konfigurace ===
# Zkopiruj tento soubor jako .env a doplni skutecne hodnoty.
# NIKDY necommituj .env do gitu!

# Gmail ucet — pouzivany pro odesilani emailu
# Musi mit zapnutou 2FA a vygenerovany App Password
# (Google Account → Security → 2-Step Verification → App passwords)
GMAIL_USER=tvuj.email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Kindle email — najdes v Amazon (Manage Content & Devices → Preferences → Personal Document Settings)
# DULEZITE: Musis pridat GMAIL_USER do "Approved Personal Document E-mail List"
KINDLE_EMAIL=tvoje.jmeno@kindle.com

# Osobni email pro archivni kopii (PDF + EPUB)
MY_EMAIL=tvuj.email@gmail.com
